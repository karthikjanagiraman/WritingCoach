ANTHROPIC_API_KEY=sk-ant-your-key-here
DATABASE_URL="file:./prisma/dev.db"

# LLM Provider Configuration (optional — defaults to Anthropic)
# LLM_PROVIDER=anthropic          # "anthropic" | "google" | "deepinfra" | "groq" | "novita"
# LLM_MODEL=claude-sonnet-4-5-20250929  # Model ID for chosen provider
# GOOGLE_AI_API_KEY=your-google-ai-key  # Required when LLM_PROVIDER=google
# DEEPINFRA_API_KEY=your-deepinfra-key  # Required when LLM_PROVIDER=deepinfra
# GROQ_API_KEY=your-groq-key            # Required when LLM_PROVIDER=groq
# NOVITA_API_KEY=your-novita-key        # Required when LLM_PROVIDER=novita
# LLM_JUDGE_MODEL=                # Override model for eval judge (defaults to LLM_MODEL)
